{
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_CONNECTION_STRING"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_MIN_32_CHAR_SECRET_IN_ENV_VARS",
    "Issuer": "BankingApi",
    "Audience": "BankingApiClients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/banking-api-.log", "rollingInterval": "Day" } }
    ]
  },
  "BankingRules": {
    "BankCodePrefix": "058",
    "MinOpeningDeposit": 500.00,
    "MinTransactionAmount": 100.00,
    "MaxTransactionAmount": 5000000.00,
    "SavingsDailyWithdrawalLimit": 200000.00,
    "CurrentDailyWithdrawalLimit": 500000.00,
    "PinMaxFailuresBeforeLock": 3,
    "PinLockDurationMinutes": 5
  },
  "Paystack": {
    "SecretKey": "sk_test_replace_with_your_key",
    "PublicKey": "pk_test_replace_with_your_key",
    "BaseUrl": "https://api.paystack.co"
  },
  "AllowedHosts": "*"
}
